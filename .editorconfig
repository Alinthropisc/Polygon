# .editorconfig — consistent coding style across editors
# Go equivalent of .clang-format for C++ / rustfmt.toml for Rust

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Go source — tabs (gofmt mandates tabs)
[*.go]
indent_style = tab
indent_size = 4
max_line_length = 120

# YAML / JSON — 2-space indent
[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

# Makefile — tabs mandatory
[Makefile]
indent_style = tab

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
